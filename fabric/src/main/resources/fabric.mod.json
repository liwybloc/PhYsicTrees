  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_authors}"
  ],
  "license": "${mod_license}",
  "environment": "*",
  "entrypoints": {
    "main": [
      "me.lilyorb.physictrees.fabric.PhYsicTreesFabric"
    ],
    "client": [
      "me.lilyorb.physictrees.fabric.PhYsicTreesFabricClient"
    ]
  },
  "mixins": [
    "physictrees.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "${minecraft_version_range}",
    "sable": ">=2.0.2"
  }
